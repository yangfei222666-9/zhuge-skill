# ═══════════════════════════════════════════════════════════════════
# 🎴 zhuge-skill · 诸葛亮 AI 推演军师 · 配置模板
# ═══════════════════════════════════════════════════════════════════
#
# 用法: 复制本文件为 `.env` (去掉 .example 后缀), 填上自己的 key.
#   cp .env.example .env    # Mac/Linux
#   copy .env.example .env  # Windows cmd
#
# ═══════════════════════════════════════════════════════════════════


# ─── ① LLM 供应商 · 关键! 不设就不会调孔明亲笔 ───
#
# ⚠️  常见坑: 只填 DEEPSEEK_API_KEY 但没写 LLM_PROVIDER → LLM 静默不调用,
#     没有"孔明亲笔"古文评. 必须同时写下面这行和对应的 key.
#
# 可选值: deepseek / doubao / kimi / qwen / zhipu / yi / baichuan / minimax
#         openai / claude / gemini / relay / ollama
#
LLM_PROVIDER=deepseek

# 对应 key (按你选的 provider 填一个即可):
DEEPSEEK_API_KEY=
# DOUBAO_API_KEY=
# KIMI_API_KEY=
# QWEN_API_KEY=
# ZHIPU_API_KEY=
# YI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# 本地 Ollama 零成本路径: LLM_PROVIDER=openai + 下面 2 行
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:7b


# ─── ② 足球数据源 (可选, 不配走 DEMO 模式) ───

# API-Football (核心数据 · 免费 100 req/day)
# 申请: https://www.api-football.com/
API_FOOTBALL_KEY=

# The Odds API (赔率 · 免费 500 req/month · 不配也能跑, 少一维数据)
# 申请: https://the-odds-api.com/
THE_ODDS_API_KEY=

# Understat (xG 期望进球 · 爬虫 · 无 key)
UNDERSTAT_ENABLED=true


# ─── ③ Windows 用户必设 (避免 ⚠ ⭐ 等字符崩溃) ───
# ⚠️  常见坑: Windows cmd 下 python 输出带非 GBK 字符会抛 UnicodeEncodeError
# 本 .env 不会自动 export, 请在 shell / bat 里 set; 或用 PowerShell
# PYTHONIOENCODING=utf-8


# ─── ④ 高级 · 一般不动 ───

# 晶体池远程地址 (公共只读 · 可 fork 后改指自己的)
# ZHUGE_REMOTE_CRYSTAL_URL=https://raw.githubusercontent.com/yangfei222666-9/zhuge-crystals/main/crystals.jsonl
